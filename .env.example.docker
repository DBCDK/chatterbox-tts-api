# Chatterbox TTS API configuration for Docker

# Server
HOST=0.0.0.0
PORT=4123
CORS_ORIGINS=*

# Model and voice sample
DEVICE=auto
VOICE_SAMPLE_PATH=/app/voice-sample.mp3
VOICE_SAMPLE_HOST_PATH=./voice-sample.mp3
MODEL_CACHE_DIR=/cache

# Model loading
MODEL_SOURCE=default
USE_MULTILINGUAL_MODEL=true

# MODEL_CLASS=multilingual
# MODEL_REPO_ID=CoRal-project/roest-v3-chatterbox-500m
# MODEL_REVISION=main
# MODEL_LOCAL_PATH=/cache/custom-model
# MODEL_SUPPORTED_LANGUAGES=da,en
# DEFAULT_LANGUAGE=da
# HF_TOKEN=
# HF_ALLOW_PATTERNS=["*.safetensors","*.json","*.txt","*.pt","*.model"]

# Generation defaults
EXAGGERATION=0.5
CFG_WEIGHT=0.5
TEMPERATURE=0.8

# Text limits
MAX_CHUNK_LENGTH=280
MAX_TOTAL_LENGTH=3000
