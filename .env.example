# Chatterbox TTS API configuration

# Server
HOST=0.0.0.0
PORT=4123
CORS_ORIGINS=*

# Model and voice sample
DEVICE=auto
VOICE_SAMPLE_PATH=./voice-sample.mp3
MODEL_CACHE_DIR=./models

# Model loading
# MODEL_SOURCE=default|hf_repo|local_dir
MODEL_SOURCE=default

# Optional when MODEL_SOURCE=default
USE_MULTILINGUAL_MODEL=true

# Required for MODEL_SOURCE=hf_repo or MODEL_SOURCE=local_dir
# MODEL_CLASS=standard
# MODEL_CLASS=multilingual

# Required for MODEL_SOURCE=hf_repo
# MODEL_REPO_ID=CoRal-project/roest-v3-chatterbox-500m
# MODEL_REVISION=main

# Required for MODEL_SOURCE=local_dir
# MODEL_LOCAL_PATH=./models/custom-model

# Required for multilingual hf_repo/local_dir models
# MODEL_SUPPORTED_LANGUAGES=da,en
# MODEL_SUPPORTED_LANGUAGES=da:Danish,en:English
# DEFAULT_LANGUAGE=da

# Optional Hugging Face auth and download filtering
# HF_TOKEN=
# HF_ALLOW_PATTERNS=["*.safetensors","*.json","*.txt","*.pt","*.model"]

# Generation defaults
EXAGGERATION=0.5
CFG_WEIGHT=0.5
TEMPERATURE=0.8

# Text limits
MAX_CHUNK_LENGTH=280
MAX_TOTAL_LENGTH=3000

# Model pool limits
MODEL_INSTANCE_COUNT=2
MAX_QUEUE_WAIT_SECONDS=10
REQUEST_TIMEOUT_SECONDS=120

# Optional cache settings
# HF_HOME=./.cache/huggingface
# TORCH_HOME=./.cache/torch
